{
  "name": "palpitetotal-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo PalpiteTotal - App Móvel & CRM Admin",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npx -y concurrently \"npm run dev --workspace=@palpitetotal/mobile\" \"npm run dev --workspace=@palpitetotal/admin\"",
    "dev:mobile": "npm run dev --workspace=@palpitetotal/mobile",
    "dev:admin": "npm run dev --workspace=@palpitetotal/admin",
    "cap:sync": "npx cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/status-bar": "^8.0.3",
    "@supabase/supabase-js": "^2.49.1"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
